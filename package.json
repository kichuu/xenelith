{
	"name": "interior-design-ai",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"@types/bun": "^1.3.4",
			"@cloudflare/workers-types": "^4.20251213.0",
			"lucide-react": "^0.546.0",
			"next-themes": "^0.4.6",
			"react": "^19.2.3",
			"react-dom": "^19.2.3",
			"sonner": "^2.0.5",
			"@prisma/client": "^7.2.0",
			"@types/react": "^19.2.10",
			"@types/react-dom": "^19.2.3",
			"tailwindcss": "^4.1.18",
			"alchemy": "^0.87.0"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F server dev",
		"db:push": "turbo -F @interior-design-ai/db db:push",
		"db:studio": "turbo -F @interior-design-ai/db db:studio",
		"db:generate": "turbo -F @interior-design-ai/db db:generate",
		"db:migrate": "turbo -F @interior-design-ai/db db:migrate",
		"deploy": "turbo -F @interior-design-ai/infra deploy",
		"destroy": "turbo -F @interior-design-ai/infra destroy",
		"check": "biome check --write ."
	},
	"dependencies": {
		"@interior-design-ai/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@cloudflare/workers-types": "catalog:",
		"@interior-design-ai/config": "workspace:*",
		"@types/bun": "catalog:",
		"turbo": "^2.8.12",
		"typescript": "^5"
	},
	"packageManager": "bun@1.3.11"
}
